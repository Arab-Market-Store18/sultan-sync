name: Transfer FLUX.2-klein-4B GGUF 
on:
  workflow_dispatch:

jobs:
  transfer:
    runs-on: ubuntu-latest
    steps:
      - name: Install huggingface_hub
        run: pip install huggingface_hub

      - name: Download and Upload FLUX.2-klein-4B GGUF
        env:
          HF_TOKEN: ${{ secrets.HF_TOKEN }}
        run: |
          python3 << 'EOF'
          import os
          from huggingface_hub import hf_hub_download, HfApi
              
          api = HfApi(token=os.environ["HF_TOKEN"])
          target_repo = "shababdd11/sultan-models"
              
          # معلومات نموذج FLUX GGUF
          flux_gguf_source_repo = "unsloth/FLUX.2-klein-4B-GGUF"
          flux_gguf_filename = "flux-2-klein-4b-Q5_K_M.gguf" # اختيار Q5_K_M كتوازن بين الحجم والجودة
          flux_gguf_target_folder = "generation/flux2-klein-4b-gguf"
              
          print(f"📥 جاري تحميل نموذج FLUX GGUF: {flux_gguf_filename}...")
          flux_gguf_local_path = hf_hub_download(
              repo_id=flux_gguf_source_repo,
              filename=flux_gguf_filename,
              local_dir="./temp_flux_gguf"
          )
              
          print(f"📤 جاري رفع نموذج FLUX GGUF إلى مستودعك في: {flux_gguf_target_folder}")
          api.upload_file(
              path_or_fileobj=flux_gguf_local_path,
              path_in_repo=f"{flux_gguf_target_folder}/{flux_gguf_filename}",
              repo_id=target_repo,
              repo_type="model",
              commit_message=f"إضافة نموذج FLUX.2-klein-4B GGUF ({flux_gguf_filename})"
          )
              
          print("✅ تمت العملية بنجاح! نموذج FLUX GGUF الآن في مستودعك.")
          EOF
